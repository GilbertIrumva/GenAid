# Copy this file to .env (or .env.local) and adjust as needed.

# Base URL the SPA uses for API calls.
#   - In dev, use the Vite proxy by keeping "/api" and configuring vite.config.ts,
#     OR point directly at your local server: http://localhost:5000/api
#   - In production, set this to your deployed API origin, e.g.
#     https://api.generationaid.org/api
VITE_API_URL=/api
