# Copy this file to .env and fill in the values.

NODE_ENV=development
PORT=5000

# MongoDB Atlas connection string
# Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/<dbname>?retryWrites=true&w=majority
MONGODB_URI=

# Random string used to sign JWT tokens. MUST be at least 32 characters.
# Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=

# Comma-separated list of origins allowed to call the API (no trailing slash).
# Example for prod: https://generationaid.org,https://www.generationaid.org
CLIENT_ORIGIN=http://localhost:5173

# Max upload size in megabytes (videos + posters share this cap per file).
UPLOAD_MAX_MB=200

# --- Cloudinary (required) ---
# All uploaded media (videos, posters, photos) is stored on Cloudinary.
# Find these on the Cloudinary dashboard: https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
